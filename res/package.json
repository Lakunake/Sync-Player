{
  "name": "sync-player",
  "version": "12.0.0",
  "description": "Feature-Rich synchronized video player for multiple clients",
  "main": "server.js",
  "scripts": {
    "start": "node --env-file-if-exists=../config.env server.js",
    "dev": "node --watch --env-file-if-exists=../config.env server.js",
    "postinstall": "node postinstall.js",
    "audit": "node audit.js"
  },
  "author": "Lakunake",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lakunake/Sync-Player"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "fast-deep-equal": "^3.1.3",
    "helmet": "^8.0.0",
    "ip": "^2.0.1",
    "jassub": "^2.4.1",
    "node-av": "^6.0.0",
    "rate-limiter-flexible": "^9.0.1",
    "socket.io": "^4.8.1"
  },
  "overrides": {
    "node-av": {
      "werift": "$werift"
    }
  },
  "optionalDependencies": {
    "werift": "npm:empty-npm-package@1.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "node-av@6.0.0": true
  }
}
